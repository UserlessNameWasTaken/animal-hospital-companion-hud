<Window x:Class="AnimalHospitalOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animal Hospital Overlay"
        Width="800" Height="465"
        MinWidth="760" MinHeight="440"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="RoomButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="43"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#566173"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#26303E"/>
            <Setter Property="Foreground" Value="#EAF0F7"/>
            <Setter Property="BorderBrush" Value="#536174"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Border Background="#E6131820" BorderBrush="#803C4656" BorderThickness="1"
            CornerRadius="12" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="ANIMAL HOSPITAL • RUN HUD" Foreground="#AEB9C8"
                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CalibrationButton" Content="CAL: OFF" Click="Calibration_Click"
                            FontSize="10" Padding="7,2"/>
                    <Button x:Name="TrackingButton" Content="TRACK: OFF" Click="Tracking_Click"
                            FontSize="10" Padding="7,2"/>
                    <Button x:Name="VisionButton" Content="VISION: OFF" Click="Vision_Click"
                            FontSize="10" Padding="7,2"
                            ToolTip="Low-frequency candidate observer; never changes HUD state automatically."/>
                    <Button x:Name="TestModeButton" Content="TEST: OFF" Click="TestMode_Click"
                            FontSize="10" Padding="7,2"/>
                    <Button Content="—" Click="Minimize_Click" Padding="9,2"/>
                    <Button Content="×" Click="Close_Click" Padding="9,2"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ROOM STATUS" Foreground="#78869A" FontSize="10"
                               FontWeight="Bold" Margin="3,0,0,4"/>
                    <Canvas Width="420" Height="190">
                        <Border Canvas.Left="20" Canvas.Top="78" Width="380" Height="28"
                                Background="#382A3442" BorderBrush="#566173" BorderThickness="1"/>
                        <Border Canvas.Left="174" Canvas.Top="78" Width="30" Height="100"
                                Background="#382A3442" BorderBrush="#566173" BorderThickness="1"/>
                        <Border Canvas.Left="118" Canvas.Top="126" Width="72" Height="28"
                                Background="#382A3442" BorderBrush="#566173" BorderThickness="1"/>
                        <TextBlock Canvas.Left="25" Canvas.Top="2" Text="EMERGENCY WING"
                                   Foreground="#9BA8B9" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="285" Canvas.Top="2" Text="MEDICAL WING"
                                   Foreground="#9BA8B9" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="111" Canvas.Top="84" Text="EMERGENCY"
                                   Foreground="#78869A" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="166" Canvas.Top="84" Text="MAIN HALL"
                                   Foreground="#B7C2D0" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="210" Canvas.Top="84" Text="MEDBAY"
                                   Foreground="#78869A" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="121" Canvas.Top="133" Text="OFFICE"
                                   Foreground="#9BA8B9" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="170" Canvas.Top="112" Text="RECEPTION"
                                   Foreground="#9BA8B9" FontSize="8" FontWeight="Bold"/>
                        <TextBlock Canvas.Left="177" Canvas.Top="162" Text="ENT"
                                   Foreground="#78869A" FontSize="8" FontWeight="Bold"/>

                        <Button x:Name="Room8" Canvas.Left="0" Canvas.Top="70" Panel.ZIndex="2"
                                Tag="8" Content="8&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room6" Canvas.Left="52" Canvas.Top="18" Panel.ZIndex="2"
                                Tag="6" Content="6&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room7" Canvas.Left="52" Canvas.Top="130" Panel.ZIndex="2"
                                Tag="7" Content="7&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room1" Canvas.Left="266" Canvas.Top="18" Panel.ZIndex="2"
                                Tag="1" Content="1&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room2" Canvas.Left="266" Canvas.Top="130" Panel.ZIndex="2"
                                Tag="2" Content="2&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room3" Canvas.Left="318" Canvas.Top="18" Panel.ZIndex="2"
                                Tag="3" Content="3&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room4" Canvas.Left="318" Canvas.Top="130" Panel.ZIndex="2"
                                Tag="4" Content="4&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                        <Button x:Name="Room5" Canvas.Left="370" Canvas.Top="70" Panel.ZIndex="2"
                                Tag="5" Content="5&#x0a;CLEAR" Style="{StaticResource RoomButton}" Click="Room_Click"/>
                    </Canvas>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="ShiftNumberText" Text="SHIFT 1" Foreground="#78869A"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="ShiftTimerText" Text="00:00.0" Foreground="White"
                                       FontSize="28" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button x:Name="ShiftButton" Content="START" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Click="Shift_Click"/>
                    </Grid>

                    <Border Background="#7A202936" CornerRadius="6" Padding="8" Margin="0,6">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="COFFEE • SMALL" Foreground="#BEC8D5"/>
                                <TextBlock x:Name="SmallCoffeeText" Text="READY" Foreground="#64D69A"
                                           FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid x:Name="TallCoffeeRow" Margin="0,6,0,0" Visibility="Collapsed">
                                <TextBlock Text="COFFEE • TALL" Foreground="#BEC8D5"/>
                                <TextBlock x:Name="TallCoffeeText" Text="READY" Foreground="#64D69A"
                                           FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#7A202936" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="PREDICTED LOCATION" Foreground="#78869A"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="TrackingConfidenceText" Text="0%"
                                           Foreground="#9BA8B9" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock x:Name="TrackingLocationText" Text="Tracking disabled"
                                       Foreground="#E8EDF4" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            <TextBlock x:Name="TrackingFacingText" Text="Facing N • No anchor"
                                       Foreground="#9BA8B9" FontSize="10" Margin="0,2,0,0"/>
                            <TextBlock x:Name="CalibrationText" Text="Calibration inactive"
                                       Foreground="#78869A" FontSize="9" Margin="0,2,0,0"/>
                            <TextBlock x:Name="VisionCandidateText" Text="Vision candidate: disabled"
                                       Foreground="#78869A" FontSize="9" Margin="0,2,0,0"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="42"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SENS" Foreground="#78869A" FontSize="9"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider x:Name="SensitivitySlider" Grid.Column="1"
                                        Minimum="0.1" Maximum="4" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" Value="0.2"
                                        ValueChanged="Sensitivity_Changed"/>
                                <TextBlock x:Name="SensitivityText" Grid.Column="2" Text="0.2"
                                           Foreground="#E8EDF4" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="RECENT SHIFTS" Foreground="#78869A" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="HistoryText" Text="No completed shifts yet."
                               Foreground="#B8C2CF" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>

            <Border x:Name="GuidePanel" Grid.Row="2"
                    Background="#F0222C38" CornerRadius="7" Padding="8">
                <StackPanel>
                    <TextBlock x:Name="GuideTitle" Text="KEYBINDS"
                               Foreground="#F3C969" FontSize="11" FontWeight="Bold"/>
                    <TextBlock x:Name="GuideText" Foreground="#E8EDF4" FontSize="11"
                               Text="End  Commands" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
